        /* ポッドキャスト埋め込み */
        .spotify-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .spotify-item {
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 12px rgba(116, 66, 56, 0.05);
            background: #fff;
            line-height: 0;
        }

        /* 卵型ボタンのグリッド */
        .button-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 12px;
        }

        .egg-button {
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: var(--bg-egg);
            color: var(--text-brown);
            text-decoration: none;
            padding: 14px 10px;
            font-size: 0.8rem;
            font-weight: 600;
            border: 2px solid var(--text-brown);
            /* 歪な卵のフォルム */
            border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
            transition: all 0.2s ease;
            box-shadow: 0 2px 4px rgba(116, 66, 56, 0.05);
        }

        .egg-button:hover {
            background-color: var(--accent-yellow);
            transform: scale(1.02);
        }

        /* 外部リンク集 */
        .link-list {
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
        }

        .link-item {
            color: var(--text-brown);
            font-size: 0.85rem;
            text-decoration: none;
            border-bottom: 1px dashed var(--text-brown);
        }

        .link-item:hover {
            color: var(--accent-red);
            border-bottom: 1px solid var(--accent-red);
        }

        /* 独り言 */
        .musing-box {
            font-size: 0.85rem;
            text-align: center;
            padding: 10px 20px;
            color: var(--text-brown);
        }

        /* 準備中ボックス */
        .coming-soon {
            text-align: center;
            font-size: 0.8rem;
            opacity: 0.6;
            padding: 24px;
            background: rgba(116, 66, 56, 0.02);
            border: 1px dashed rgba(116, 66, 56, 0.2);
            border-radius: 8px;
